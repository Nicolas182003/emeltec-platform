# ⚠️ Copia este archivo como .env y completa con tus credenciales reales
# NUNCA subas el archivo .env a GitHub

# Servidor
PORT=3001

# Base de datos TimescaleDB (mismas credenciales que infra-db)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=db_infra
DB_USER=admin_infra
DB_PASSWORD=TU_PASSWORD_AQUI

# API Key — clave secreta para autenticar los requests
# Cámbiala por una cadena larga y aleatoria en producción
ADMIN_API_KEY=TU_API_KEY_AQUI
