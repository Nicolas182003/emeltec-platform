NODE_ENV=development
PORT=3002

DB_HOST=localhost
DB_PORT=5433
DB_NAME=telemetry_platform
DB_USER=postgres
DB_PASSWORD=admin_password

JWT_SECRET=super_secret_dev_key_12345
INTERNAL_API_KEY=dev_internal_key

# URL base de la API externa de la DGA (Chile)
DGA_API_URL=https://dga.mop.gob.cl/api

# Modo mock: simula respuesta exitosa de la DGA sin llamar al endpoint real
# Usar mientras no se tenga el endpoint oficial. Cambiar a "false" en producción.
DGA_MOCK_MODE=true
